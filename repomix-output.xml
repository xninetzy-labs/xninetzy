def test_log_and_latest_trace():
    _setup()
    chat = "trace-chat-1"
    tid = log_trace(user_id="u", chat_id=chat, message_id="m1",
                    input_text="halo", response_text="hai", intent="direct",
                    tools_used=["datetime_now"])
