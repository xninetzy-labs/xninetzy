    for row in rows:
        lines.append(f"#{row['id']} - {row['title']}")
        lines.append(f"  Tipe: {row['action_type']}")
    return "\n".join(lines)


@tool
def hitl_approve(approval_id: int, sender_id: str | None = None, sender_name: str | None = None) -> str:
    """Approve request. Hanya admin."""
