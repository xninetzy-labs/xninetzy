nurl}}\n                    <img alt=\"{{alttext}}\" title=\"{{alttext}}\" src=\"{{{ iconurl }}}\" class=\"icon {{iconclass}}\">\n                {{/iconurl}}\n                {{^iconurl}}\n                    {{#pix}} {{key}}, {{component}}, {{alttext}} {{/pix}}\n                {{/iconurl}}\n                {{/icon}}\n            </div>\n            <div class=\"event-name-container flex-grow-1 line-height-3 nowrap text-truncate\">\n                <div class=\"d-flex\">\n                    <h6 class=\"event-name mb-0 pb-1 text-truncate\">\n                        {{#overdue}}<span class=\"badge rounded-pill bg-danger text-white ms-1 float-end\">{{#str}} overdue, block_timeline {{/str}}</span>{{/overdue}}\n                        <a href=\"{{url}}\"\n                                title=\"{{name}}\"\n                                aria-label='{{#cleanstr}} ariaeventlistitem, block_timeline, { \"name\": {{#quote}}{{{activityname}}}{{/quote}}, \"course\": {{#quote}}{{{course.fullnamedisplay}}}{{/quote}}, \"date\": \"{{#userdate}} {{timesort}}, {{#str}} strftimedatetime, core_langconfig {{/str}} {{/userdate}}\" } {{/cleanstr}}'>\n                            {{{activityname}}}</a>\n                    </h6>\n                </div>\n                <small class=\"mb-0\">\n                    {{#courseview}}\n                        {{activitystr}}\n                    {{/courseview}}\n                    {{^courseview}}\n                        {{activitystr}}{{#course.fullnamedisplay}} &middot; {{{course.fullnamedisplay}}}{{/course.fullnamedisplay}}\n                    {{/courseview}}\n                </small>\n            </div>\n        </div>\n        {{#action.actionable}}\n        <div class=\"d-flex timeline-action-button\">\n            <h6 class=\"event-action\">\n                <a class=\"list-group-item-action btn btn-outline-secondary btn-sm text-nowrap\"\n                    href=\"{{action.url}}\"\n                    aria-label=\"{{action.name}}\"\n                    title=\"{{action.name}}\">\n                {{{action.name}}}\n                {{#action.showitemcount}}\n                <span class=\"badge bg-secondary text-dark\">{{action.itemcount}}</span>\n                {{/action.showitemcount}}\n                </a>\n            </h6>\n        </div>\n        {{/action.actionable}}\n    </div>\n    <div class=\"pt-2 border-bottom\"></div>\n</div>\n"}, {"name": "1970041978/core_str/resettouronpage/tool_usertours/en", "value": "Reset user tour on this page"}, {"name": "1970041978/core_template/1777107865:boost/core/modal_save_cancel", "value": "\n\n\n{{< core/modal }}\n    {{$footer}}\n        <button type=\"button\" class=\"btn btn-secondary\" data-action=\"cancel\">{{#str}} cancel {{/str}}</button>\n        <button type=\"button\" class=\"btn btn-primary\" data-action=\"save\">{{#str}} savechanges {{/str}}</button>\n    {{/footer}}\n{{/ core/modal }}\n"}, {"name": "1970041978/core_str/overdue/block_timeline/en", "value": "Overdue"}, {"name": "1970041978/core_str/strftimedaydate/core_langconfig/en", "value": "%A, %d %B %Y"}, {"name": "1970041978/core_str/moreevents/calendar/en", "value": "{$a} more"}, {"name": "1970041978/core_str/savechanges/core/en", "value": "Save changes"}, {"name": "1970041978/core_str/delete/core/en", "value": "Delete"}, {"name": "1970041978/core_str/strftimetime24/core_langconfig/en", "value": "%H:%M"}, {"name": "1970041978/core_template/1777107865:boost/core/modal", "value": "\n\n\n<div class=\"modal moodle-has-zindex\" data-region=\"modal-container\" aria-hidden=\"true\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"{{uniqid}}-modal-title\">\n    <div class=\"modal-dialog {{$classes}}{{classes}}{{/classes}}\" data-region=\"modal\" tabindex=\"0\">\n        <div class=\"modal-content\">\n            <div class=\"modal-header {{$headerclasses}}{{headerclasses}}{{/headerclasses}}\" data-region=\"header\">\n\n                {{$header}}\n                    <h5 id=\"{{uniqid}