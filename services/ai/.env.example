# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# AI FastAPI
AI_API_HOST=0.0.0.0
AI_API_PORT=8000
AI_API_KEY=
DATA_DIR=/app/data
SQLITE_PATH=/app/data/xninetzy.sqlite3

# Skills
SKILLS_ENABLED=true
SKILL_DEBUG_ENDPOINTS=true

# Obsidian
OBSIDIAN_ENABLED=true
OBSIDIAN_VAULT_HOST_PATH=~/Documents/xninetzy
OBSIDIAN_VAULT_PATH=/app/obsidian-vault
OBSIDIAN_ALLOW_WRITE=true
OBSIDIAN_ALLOW_DELETE=false
OBSIDIAN_BACKUP_BEFORE_WRITE=true
OBSIDIAN_MAX_FILE_SIZE_MB=5

# Reminder
REMINDER_ENABLED=true
APP_TIMEZONE=Asia/Jakarta
REMINDER_POLL_INTERVAL_SECONDS=30
WA_MCP_BASE_URL=http://wa-enggine:8081
WA_MCP_API_KEY=

# Workflow
WORKFLOW_ENABLED=true
WORKFLOW_REQUIRE_CONFIRMATION=true

# Bot Identity
BOT_NAME=Xninetzy AI
BOT_OWNER=Misbahul Muttaqin

# Admin / Deep Research
ADMIN_JID=
ADMIN_NAMES=misbahul,misbahul muttaqin
DEEP_RESEARCH_ADMIN_ONLY=true
DEEP_RESEARCH_ALLOW_GROUP_ADMINS=true
DEEP_RESEARCH_ALLOW_ADMIN_NAMES=true

# HITL Approval
HITL_ENABLED=true
HITL_REQUIRE_FOR_RESEARCH_SAVE=true
HITL_REQUIRE_FOR_ROADMAP_ACTIVATION=true
HITL_REQUIRE_FOR_HEBAT_UPLOAD=true
HITL_REQUIRE_FOR_BULK_TASK_CREATE=true
HITL_REQUIRE_FOR_OBSIDIAN_WRITE=false
HITL_REQUIRE_FOR_GRAPH_RAG_WRITE=true
