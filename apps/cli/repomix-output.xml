<file path="src/components/InputBox.tsx">
import React from 'react';
import { Box, Text } from 'ink';
import TextInput from 'ink-text-input';
import { colors } from '../theme/colors.js';

type InputBoxProps = {
  value: string;
  onChange: (value: string) => void;
  onSubmit: (value: string) => void;
  width: number;
};

export function InputBox({ value, onChange, onSubmit, width }: InputBoxProps) {
  // Logic to split huge input into [Summary] + [Editable Part]
  // We treat everything before the last newline as the "Huge Part" if it's large.
  
  const lastNewlineIndex = value.lastIndexOf('\n');
  
  let prefix = '';
  let activePart = value;
  
  if (lastNewlineIndex !== -1) {
    prefix = value.slice(0, lastNewlineIndex);
    activePart = value.slice(lastNewlineIndex + 1);
  }

  const prefixLines = prefix ? prefix.split('\n').length : 0;
  const prefixChars = prefix.length;
  
  // Only show summary if the prefix is significant
  const showSummary = prefixLines > 3 || prefixChars > 200;

  const handleActivePartChange = (newValue: string) => {
    if (showSummary) {
      onChange(prefix + '\n' + newValue);
    } else {
      onChange(newValue);
    }
  };

  const handleActivePartSubmit = (activeValue: string) => {
    if (showSummary) {
      onSubmit(prefix + '\n' + activeValue);
    } else {
      onSubmit(activeValue);
    }
  };

  return (
    <Box width={width} flexDirection="column" paddingX={1}>
      <Box
        width={width - 2}
        borderStyle="single"
        borderColor={showSummary ? colors.orange : colors.border}
        paddingX={1}
      >
        <Text color={colors.orange}>◎ </Text>
        
        {showSummary && (
          <Box marginRight={1}>
            <Text color={colors.orangeBright} bold>
              [{prefixLines} lines] 
            </Text>
            <Text color={colors.dim}> ▸ </Text>
          </Box>
        )}

        <Box flexGrow={1}>
          <TextInput
            value={activePart}
            onChange={handleActivePartChange}
            onSubmit={handleActivePartSubmit}
            placeholder={showSummary ? 'Add a comment...' : 'Ask anything... "halo"'}
            showCursor
          />
        </Box>
      </Box>
      
      {showSummary && (
          <Box paddingX={1}>
              <Text color={colors.dim} italic>
                  Large payload detected. Typing at the end of buffer. 
                  Press ESC in chat to clear.
              </Text>
          </Box>
      )}
    </Box>
  );
}
